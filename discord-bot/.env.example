# Discord Bot Configuration
DISCORD_TOKEN=                    # Bot token from Discord Developer Portal
CLIENT_ID=                        # Bot application client ID
GUILD_ID=                         # Discord server ID for slash command registration
ALERT_CHANNEL_ID=                 # Channel ID where proactive alerts are posted
COMMAND_PREFIX=!                  # Prefix for message-based commands

# Backend API Configuration
BACKEND_BASE_URL=http://localhost:3000   # Backend REST base URL
BACKEND_WS_URL=ws://localhost:3000       # Backend WebSocket URL

# Optional LLM Configuration (leave blank to disable)
GROQ_API_KEY=                     # Groq API key for humanized responses
GROQ_MODEL=llama-3.3-70b-versatile  # Model to use for humanization
