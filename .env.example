# Server
PORT=5000
HOST=localhost

# WebSocket
WS_PORT=8080

# Office Hours (24-hour format)
OFFICE_START_HOUR=9
OFFICE_END_HOUR=17

# Simulator
SIMULATOR_INTERVAL_MIN=30000
SIMULATOR_INTERVAL_MAX=60000

# Alert Config
ENABLE_AFTER_HOURS_ALERTS=true
ENABLE_RUNTIME_ALERTS=true
CONTINUOUS_RUNTIME_THRESHOLD_HOURS=2

# Logging
LOG_LEVEL=info
